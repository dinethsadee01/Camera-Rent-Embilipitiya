{
  "expo": {
    "name": "Camera Rent",
    "slug": "CameraRent",
    "version": "1.0.0",
    "scheme": "camerarent",
    "orientation": "portrait",
    "icon": "./assets/camerarentapplogo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/Logo-black.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Camera Rent to use Face ID for secure login."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Camera Rent to access your photos for customer ID photos.",
          "cameraPermission": "Allow Camera Rent to use the camera for taking ID photos."
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.camerarent.embilipitiya",
      "splash": {
        "image": "./assets/Logo-black.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff",
        "dark": {
          "image": "./assets/Logo-white.png",
          "backgroundColor": "#000000"
        }
      }
    },
    "android": {
      "splash": {
        "image": "./assets/Logo-black.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff",
        "dark": {
          "image": "./assets/Logo-white.png",
          "backgroundColor": "#000000"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.camerarent.embilipitiya"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
